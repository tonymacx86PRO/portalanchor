	"authors": [
		"Vergil"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/tonymacx86PRO/portalanchor"
	},
	"license": "CC0-1.0",
	"icon": "assets/portalanchor/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.y4mato.portalanchor.PortalAnchor"
		]
	},
	"mixins": [
		"portalanchor.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~26.1.2",
		"java": ">=25",
		"fabric-api": "*"
	}
